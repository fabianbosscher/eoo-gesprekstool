# Database
# Lokaal: DATABASE_URL="file:./dev.db" (SQLite, geen DIRECT_URL nodig)
# Productie (Supabase): gebruik Transaction URL (port 6543) voor DATABASE_URL
#                       en Direct URL (port 5432) voor DIRECT_URL
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genereer-een-geheim-met-openssl-rand-base64-32"

# Anthropic / Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# Resend (e-mail)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@easyofficeonline.nl"

# App URL (voor links in e-mails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
